PORT=3000
DATABASE_PATH=./data/prices.db
LOG_LEVEL=info
METRICS_RETENTION_DAYS=30

# Auth
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-a-different-random-secret

# App
APP_URL=http://localhost:3000
EMAIL_FROM=noreply@pricetracker.app

# Email delivery (optional — emails are logged to console if not set)
SENDGRID_API_KEY=
